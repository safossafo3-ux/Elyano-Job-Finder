# JobRadar — environment variables
# Copy this file to .env and fill in your keys.

# Telegram Bot — talk to @BotFather to create a bot, then send /start to it
# and visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Gemini — get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Scheduler (comma-separated hours in 24h format)
SCAN_CRON_HOURS=8,20
SCAN_CRON_TZ=Africa/Cairo

# Scraping
HEADLESS=true
PAGE_TIMEOUT_MS=30000
MAX_JOBS_PER_PORTAL=20

# Webapp
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8000

# Database (leave empty to use default: <project_root>/jobradar.db)
# DATABASE_PATH=jobradar.db
