# JobRadar — environment variables
# Copy to .env and fill in your keys.

# === Telegram ===
# 1. Talk to @BotFather → /newbot → copy the token
# 2. Set a username for your bot (e.g. MustafaJobRadar_bot)
# 3. Send /start to your bot to register your chat
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=

# === Google Gemini ===
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# === Scheduler ===
SCAN_CRON_HOURS=8,20
SCAN_CRON_TZ=Africa/Cairo

# === Scraping ===
HEADLESS=true
PAGE_TIMEOUT_MS=30000
MAX_JOBS_PER_PORTAL=15
REALTIME_NOTIFY=true

# === Webapp ===
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8000
SESSION_SECRET=change-this-to-a-random-string
# The public URL of your dashboard (used in bot messages and email digests)
WEBAPP_PUBLIC_URL=https://your-app-name.up.railway.app

# === Phase 3: Admin ===
# Comma-separated list of Telegram usernames who get admin privileges
# (e.g. your_own_username) — they'll see the Admin tab.
ADMIN_TELEGRAM_USERNAMES=

# === Phase 3: Email notifications (optional) ===
# Configure SMTP to send email digests and alerts.
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USE_SSL=false,
#   use an "App Password" from your Google Account (not your normal password).
# For SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey,
#   SMTP_PASSWORD=<your_sendgrid_api_key>.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=JobRadar
SMTP_USE_SSL=false

# === Phase 3: Rate limiting (per minute) ===
RATE_LIMIT_PER_MINUTE_AUTH=60
RATE_LIMIT_PER_MINUTE_ANON=15

# === Phase 3: Resume uploads ===
# Max file size in bytes (default 5 MB)
MAX_RESUME_SIZE_BYTES=5242880

# === Database (leave empty to use default) ===
# DATABASE_PATH=jobradar.db
